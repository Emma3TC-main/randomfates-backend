{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Result",
  "type": "object",
  "required": [
    "id",
    "executionId",
    "verificationHash",
    "winners",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "executionId": {
      "type": "string",
      "format": "uuid"
    },
    "verificationHash": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "winners": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "position",
          "participant"
        ],
        "properties": {
          "position": {
            "type": "integer",
            "minimum": 1
          },
          "participant": {
            "type": "object"
          },
          "prize": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    }
  }
}