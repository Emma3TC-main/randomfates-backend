{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BulkParticipantsRequest",
  "type": "object",
  "required": [
    "participants"
  ],
  "properties": {
    "filename": {
      "type": "string",
      "default": "manual-bulk.json"
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "$ref": "create-participant-request.schema.json"
      }
    }
  },
  "additionalProperties": false
}