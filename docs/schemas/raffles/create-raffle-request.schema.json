{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CreateRaffleRequest",
  "type": "object",
  "required": [
    "title"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 150
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "type": {
      "enum": [
        "ROULETTE",
        "SLOT",
        "RANDOM_PICKER"
      ],
      "default": "ROULETTE"
    },
    "configuration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "winnersCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "allowDuplicates": {
          "type": "boolean"
        },
        "animation": {
          "type": "string"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "isPublic": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}