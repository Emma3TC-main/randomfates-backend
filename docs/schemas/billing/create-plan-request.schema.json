{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CreatePlanRequest",
  "type": "object",
  "required": [
    "name",
    "price"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100
    },
    "price": {
      "type": "number",
      "minimum": 0
    },
    "features": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}