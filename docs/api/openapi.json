{
  "openapi": "3.1.0",
  "info": {
    "title": "RandomFates Backend API",
    "version": "1.0.0",
    "description": "API REST para gestión y ejecución auditable de sorteos digitales."
  },
  "servers": [
    {
      "url": "http://localhost:3000/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ApiSuccess": {
        "type": "object",
        "required": [
          "success",
          "message",
          "data"
        ],
        "properties": {
          "success": {
            "const": true
          },
          "message": {
            "type": "string"
          },
          "data": {},
          "meta": {
            "type": "object"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "required": [
          "success",
          "message",
          "error"
        ],
        "properties": {
          "success": {
            "const": false
          },
          "message": {
            "type": "string"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "details": {}
            }
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "CreateRaffleRequest": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "enum": [
              "ROULETTE",
              "SLOT",
              "RANDOM_PICKER"
            ]
          },
          "configuration": {
            "type": "object"
          },
          "isPublic": {
            "type": "boolean"
          }
        }
      },
      "CreateParticipantRequest": {
        "type": "object",
        "required": [
          "fullName",
          "identifier"
        ],
        "properties": {
          "fullName": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "source": {
            "enum": [
              "MANUAL",
              "CSV",
              "API"
            ]
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "CreatePrizeRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "SubscribeRequest": {
        "type": "object",
        "required": [
          "planId"
        ],
        "properties": {
          "planId": {
            "type": "string",
            "format": "uuid"
          },
          "months": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Estado general",
