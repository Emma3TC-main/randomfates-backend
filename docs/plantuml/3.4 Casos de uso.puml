@startuml
' Configuración para orientación horizontal y optimización A4
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundcorner 10

' Estilo visual para que se vea más profesional
skinparam actor {
    BackgroundColor White
    BorderColor Black
}
skinparam usecase {
    BackgroundColor GhostWhite
    BorderColor Black
}

actor Organizador
actor Administrador
actor Participante

rectangle "Sistema de Gestión de Sorteos" {
    
    package "Gestión de Sorteos" {
        Organizador -- (Crear sorteo)
        Organizador -- (Configurar sorteo)
        Organizador -- (Gestionar participantes)
    }
    
    package "Ejecución y Resultados" {
        Organizador -- (Ejecutar sorteo)
        Organizador -- (Ver resultados)
        Organizador -- (Compartir resultados)
        
        (Ver resultados) -- Participante
    }
    
    package "Administración y Premium" {
        Organizador -- (Suscribirse)
        
        (Gestionar usuarios) -- Administrador
        (Auditar sorteos) -- Administrador
        (Ver KPIs) -- Administrador
    }
}

@enduml